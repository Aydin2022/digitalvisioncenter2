SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Indqam1vcXhmeXd0aXhocmdnc2pjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAxMDQzMDEsImV4cCI6MjA5NTY4MDMwMX0.AFjHUkGMlY1D_ZF1QNRVVUdU8QhAFRBEsnJpny_En0k"

