# ============================================
# Zain Cash Configuration
# ============================================
VITE_ZAINCASH_CLIENT_ID=your_client_id_here
VITE_ZAINCASH_MSISDN=your_msisdn_here
VITE_ZAINCASH_API_URL=https://pg-api.zaincash.iq

# Server-side only (NOT prefixed with VITE_ for security)
ZAINCASH_CLIENT_SECRET=your_client_secret_here

# ============================================
# Supabase Configuration
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# Environment
# ============================================
NODE_ENV=development
